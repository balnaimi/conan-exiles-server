# ============================================
# CONAN EXILES DEDICATED SERVER - FULL CONFIGURATION
# ============================================
# Copy this file to .env and edit as needed:
#   cp .env.example .env
#
# Lines starting with # are comments (disabled).
# Uncomment (remove #) to override the default value.
# After changing, restart: docker compose restart

# ============================================
# SERVER INFO
# ============================================

# Server name shown in the server browser
SERVER_NAME=My Conan Server

# Password to join (empty = public server, anyone can join)
SERVER_PASSWORD=

# Server type: pve (peaceful), pvp (fight), pve-c (pve with scheduled pvp hours)
SERVER_TYPE=pve

# Max players allowed at the same time (1-40)
MAX_PLAYERS=40

# Message of the day shown when players connect
# SERVER_MOTD=Welcome to our server!

# Region: 0=EU, 1=NA, 2=Asia, 3=Oceania, 4=SA, 5=Japan
# EU is closest to Middle East
SERVER_REGION=0

# Server community type (0=none, 1=purist, 2=relaxed, 3=hard core, 4=role playing, 5=experimental)
# SERVER_COMMUNITY=0

# Nudity level (0=none, 1=partial, 2=full)
# MAX_NUDITY=2

# Creative mode (0=off, 1=on) - unlimited resources, instant crafting
# CREATIVE_MODE=0

# Timezone (examples: UTC, America/New_York, Europe/London, Asia/Qatar, Asia/Tokyo)
TZ=UTC

# ============================================
# ADMIN & RCON
# ============================================

# In-game admin password (use MakeMeAdmin command in console)
ADMIN_PASSWORD=changeme

# RCON remote console - control server remotely (True/False)
RCON_ENABLED=False
RCON_PASSWORD=changeme
RCON_PORT=25575
# RCON_MAX_KARMA=60

# ============================================
# NETWORK & PORTS
# ============================================

SERVER_PORT=7777
QUERY_PORT=27015

# Kick AFK players after this many seconds (default: 2700 = 45 min)
# KICK_AFK_TIME=2700

# Server must be this % full before AFK kick activates (default: 80)
# KICK_AFK_PERCENTAGE=80

# Max allowed ping, 0 = no limit
# MAX_ALLOWED_PING=0

# Enable login queue when server is full (True/False)
# ENABLE_LOGIN_QUEUE=True

# Seconds before disconnected player is removed (grace period)
# DISCONNECTION_GRACE_TIME=180

# Allow family shared Steam accounts to join (True/False)
# ALLOW_FAMILY_SHARE=True

# Anti-cheat
BATTLEYE_ENABLED=False
# VAC_ENABLED=False

# ============================================
# COMBAT & DAMAGE
# ============================================

# Player damage dealt multiplier (1.0 = normal, 2.0 = deal double damage)
# PLAYER_DAMAGE=1.0

# Player damage taken multiplier (1.0 = normal, 0.5 = take half damage)
# PLAYER_DAMAGE_TAKEN=1.0

# NPC/enemy damage dealt (1.0 = normal, 2.0 = enemies hit harder)
# NPC_DAMAGE=1.0

# NPC/enemy damage taken (1.0 = normal, 2.0 = enemies die faster)
# NPC_DAMAGE_TAKEN=1.0

# Follower (minion) damage dealt
# MINION_DAMAGE=1.0

# Follower (minion) damage taken
# MINION_DAMAGE_TAKEN=1.0

# Thrall damage to players (0.5 = half damage to players)
# THRALL_DAMAGE_TO_PLAYERS=0.5

# Thrall damage to NPCs (0.5 = half damage to NPCs)
# THRALL_DAMAGE_TO_NPCS=0.5

# Friendly fire damage (damage to your own clan members)
# FRIENDLY_FIRE_DAMAGE=0.25

# Structure damage multiplier
# STRUCTURE_DAMAGE=1.0

# Structure health multiplier (2.0 = structures have double HP)
# STRUCTURE_HEALTH=1.0

# Building damage multiplier
# BUILDING_DAMAGE=1.0

# Can players damage their own structures? (True/False)
# CAN_DAMAGE_OWN_STRUCTURES=False

# Dynamic building damage - buildings only take damage at certain times (True/False)
# DYNAMIC_BUILDING_DAMAGE=False

# Dynamic building damage check period (seconds)
# DYNAMIC_BUILDING_DAMAGE_PERIOD=1800

# Limit building damage to resource cost (True/False)
# CLAMP_BUILDING_DAMAGE=True

# Player knockback multiplier
# PLAYER_KNOCKBACK=1.0

# NPC knockback multiplier
# NPC_KNOCKBACK=1.0

# Consciousness/knockout damage multiplier
# CONSCIOUSNESS_DAMAGE=1.0

# Enable target lock in combat (True/False)
# ENABLE_TARGET_LOCK=True

# Enable fatality/finishing moves (True/False)
# ENABLE_FATALITIES=True

# PvP mount endurance damage multiplier
# PVP_MOUNT_ENDURANCE_DAMAGE=1.0

# Combat mode modifier (0=default)
# COMBAT_MODE_MODIFIER=0

# ============================================
# DEATH & LOOTING
# ============================================

# Can all players loot dead player bodies? (True/False)
# True = anyone can loot corpses, False = only the owner
EVERYBODY_LOOT_CORPSE=True

# Can all players open any container/chest? (True/False)
# True = anyone can open, False = only the owner
# CONTAINERS_IGNORE_OWNERSHIP=True

# Character stays in world after logout? (True/False)
# True = your body stays and can be killed/looted while offline
# LOGOUT_REMAIN=True

# How long unconscious body stays after logout (seconds, 1800 = 30 min)
# UNCONSCIOUS_TIME=1800

# How long offline player bodies persist (hours, 168 = 7 days)
# OFFLINE_BODY_HOURS=168

# Max corpses kept per player (oldest removed when exceeded)
# CORPSES_PER_PLAYER=10

# How long player corpses last (seconds, 1800 = 30 min)
# PLAYER_CORPSE_LIFETIME=1800

# How long NPC corpses last (seconds, 600 = 10 min)
# NPC_CORPSE_LIFETIME=600

# ============================================
# XP & PROGRESSION
# ============================================

# Overall XP rate (1.0 = normal, 2.0 = level up twice as fast)
# XP_RATE=1.0

# XP from killing enemies
# XP_KILL=1.0

# XP from harvesting resources
# XP_HARVEST=1.0

# XP from crafting items
# XP_CRAFT=1.0

# Passive XP gained over time
# XP_TIME=1.0

# ============================================
# HARVESTING & CRAFTING
# ============================================

# Resource harvest amount (2.0 = get double resources from nodes)
# HARVEST_AMOUNT=1.0

# Resource respawn speed (lower = respawn faster, 0.5 = twice as fast)
# RESOURCE_RESPAWN=1.0

# Food/item spoil rate (higher = spoils faster, 0.5 = lasts twice as long)
# ITEM_SPOIL_RATE=1.0

# Crafting material cost (0.5 = half materials needed)
# CRAFTING_COST=1.0

# Fuel burn time (2.0 = fuel lasts twice as long in furnaces etc.)
# FUEL_BURN_TIME=1.0

# Item conversion speed (for tanning etc.)
# ITEM_CONVERSION=1.0

# Minimum durability after repair (0.1 = 10%)
# ITEM_REPAIR_MIN_DURABILITY=0.1

# Chance of durability loss on repair (1.0 = always, 0 = never)
# ITEM_REPAIR_PENALTY_CHANCE=1.0

# ============================================
# SURVIVAL (HUNGER & THIRST)
# ============================================

# How fast you get thirsty while active (0 = never, 2.0 = twice as fast)
# ACTIVE_THIRST=1.0

# How fast you get thirsty while idle
# IDLE_THIRST=1.0

# How fast you get thirsty while offline
# OFFLINE_THIRST=1.0

# How fast you get hungry while active (0 = never, 2.0 = twice as fast)
# ACTIVE_HUNGER=1.0

# How fast you get hungry while idle
# IDLE_HUNGER=1.0

# How fast you get hungry while offline
# OFFLINE_HUNGER=1.0

# ============================================
# DROP ON DEATH
# ============================================

# Drop equipped items on death? (True/False)
# DROP_EQUIPMENT_ON_DEATH=True

# Drop quickbar/shortcut items on death? (True/False)
# DROP_SHORTCUTBAR_ON_DEATH=True

# Drop backpack contents on death? (True/False)
# DROP_BACKPACK_ON_DEATH=True

# ============================================
# DAY/NIGHT CYCLE
# ============================================

# Overall day/night cycle speed (higher = faster days)
# DAY_CYCLE_SPEED=1.0

# Daytime speed (lower = longer days)
# DAYTIME_SPEED=0.25

# Nighttime speed (lower = longer nights)
# NIGHTTIME_SPEED=0.25

# Dawn/dusk transition speed
# DAWN_DUSK_SPEED=0.25

# Players catch up to server time when joining (True/False)
# USE_CATCHUP_TIME=True

# ============================================
# PLAYER STATS
# ============================================

# Player max health multiplier (2.0 = double HP)
# PLAYER_HEALTH=1.0

# Player max stamina multiplier (2.0 = double stamina pool)
# PLAYER_STAMINA=1.0

# ============================================
# STAMINA & MOVEMENT
# ============================================

# Stamina cost multiplier (0.5 = actions use half stamina)
# STAMINA_COST=1.0

# Sprint stamina cost (0.5 = sprinting uses half stamina)
# STAMINA_SPRINT_COST=1.0

# Player walk speed (1.0 = normal, 1.5 = 50% faster)
# PLAYER_MOVE_SPEED=1.0

# Player sprint speed (1.0 = normal)
# PLAYER_SPRINT_SPEED=1.0

# Health regeneration speed (2.0 = heal twice as fast)
# HEALTH_REGEN_SPEED=1.0

# Stamina regeneration speed
# STAMINA_REGEN_SPEED=1.0

# Carry weight multiplier (2.0 = carry twice as much)
# PLAYER_ENCUMBRANCE=1.0

# Encumbrance penalty multiplier (speed reduction when heavy)
# PLAYER_ENCUMBRANCE_PENALTY=1.0

# Time to regenerate full stamina (seconds)
# STAMINA_REGEN_TIME=3.75

# Time to recover from exhaustion (seconds)
# STAMINA_EXHAUSTION_TIME=3.75

# Stamina regen rate while standing still
# STAMINA_STATIC_REGEN=1.0

# Stamina regen rate while moving
# STAMINA_MOVING_REGEN=1.0

# Pause before stamina starts regenerating after using it (seconds)
# STAMINA_CONSUME_PAUSE=1.3

# Pause before stamina starts regenerating after full exhaustion (seconds)
# STAMINA_EXHAUSTION_PAUSE=2.75

# ============================================
# THRALLS & FOLLOWERS
# ============================================

# Thrall conversion time on the wheel (0.5 = converts twice as fast)
# THRALL_CONVERSION=1.0

# Thrall scouting time in minutes
# THRALL_SCOUTING_TIME=10

# Minimum distance thrall can wander from home
# THRALL_MIN_DISTANCE=5000

# Thrall teleport cooldown (seconds, when thrall teleports to you)
# THRALL_TELEPORT_COOLDOWN=10

# Thrall exclusion radius (min distance between placed thralls)
# THRALL_EXCLUSION_RADIUS=100

# Use follower population limit? (True/False)
# When True, limits total followers per clan
# USE_MINION_POP_LIMIT=False

# Base follower limit for the clan
# MINION_POP_BASE=50

# Extra followers allowed per player in clan
# MINION_POP_PER_PLAYER=5

# Time before excess followers are removed (minutes)
# MINION_OVERPOP_CLEANUP=60

# How many followers over the limit are tolerated
# MINION_OVERPOP_ALLOWED=10

# Followers can be knocked down instead of killed (True/False)
# ENABLE_FOLLOWER_DBNO=True

# Can only rescue followers on your land claim (True/False)
# ENABLE_FOLLOWER_RESCUE=True

# Can rescue followers in build exclusion zones? (True/False)
# FOLLOWER_RESCUE_EXCLUSION=False

# Cooldown between follower rescues (seconds, 3600 = 1 hour)
# FOLLOWER_RESCUE_COOLDOWN=3600

# Must be out of combat this long before rescue (seconds)
# DAMAGE_COOLDOWN_RESCUE=600

# Thrall corruption removal speed
# THRALL_CORRUPTION_REMOVAL=1.0

# Player corruption gain multiplier (0.5 = gain corruption slower)
# PLAYER_CORRUPTION_GAIN=1.0

# Corruption gain from sorcery specifically
# PLAYER_CORRUPTION_SORCERY=1.0

# Animal pen crafting time (0.5 = animals tame twice as fast)
# ANIMAL_PEN_CRAFT_TIME=1.0

# Feed box effective range (2.0 = covers twice the area)
# FEED_BOX_RANGE=1.0

# ============================================
# BUILDING & DECAY
# ============================================

# Land claim radius (how far your territory extends)
# LAND_CLAIM_RADIUS=1.0

# Allow building anywhere including restricted areas? (True/False)
# BUILD_ANYWHERE=False

# Allow picking up placed buildings? (True/False)
# BUILDING_PICKUP=True

# Stability loss multiplier (higher = buildings collapse more easily)
# STABILITY_LOSS=1.0

# Disable building decay entirely? (True/False)
# True = buildings never decay
# DISABLE_BUILDING_DECAY=True

# Max building decay time (seconds, 1296000 = 15 days)
# MAX_BUILDING_DECAY_TIME=1296000

# Time before abandoned buildings auto-demolish (seconds, 604800 = 7 days after decay)
# MAX_DECAY_AUTO_DEMOLISH=604800

# Disable thrall/follower decay? (True/False)
# DISABLE_THRALL_DECAY=True

# Thrall decay time (seconds, 1296000 = 15 days)
# THRALL_DECAY_TIME=1296000

# Decay time per building score
# BUILDING_DECAY_PER_SCORE=5400

# Building decay time multiplier
# BUILDING_DECAY_MULTIPLIER=1.0

# Cleanup time after building decays
# DECAY_CLEANUP_MULTIPLIER=2.0

# Bonus time added to decay
# DECAY_BONUS_TIME_RATE=600

# Show building score to players (True/False)
# DECAY_SHOW_SCORE=False

# Protect Points of Interest from building (True/False)
# POI_PROTECTION=False

# Validate building placement (True/False)
# BUILDING_VALIDATION=False

# Building preload radius (how far to preload building chunks)
# BUILDING_PRELOAD_RADIUS=80

# Disable land claim notifications (True/False)
# DISABLE_LANDCLAIM_NOTIFICATIONS=True

# NPC camps ignore land claims (True/False)
# CAMPS_IGNORE_LANDCLAIM=True

# ============================================
# NPC & WORLD
# ============================================

# NPC health multiplier (2.0 = enemies have double HP)
# NPC_HEALTH=1.0

# NPC respawn speed (lower = respawn faster, 0.5 = twice as fast)
# NPC_RESPAWN=1.0

# Max NPCs that can spawn at once
# NPC_MAX_SPAWN_CAP=1.0

# Max aggro range (how far NPCs detect you)
# MAX_AGGRO_RANGE=9000

# Enable ambient wildlife like rabbits, deer etc. (True/False)
# AMBIENT_LIFE=True

# NPC mind reading mode (0=off) - NPCs react to player actions
# NPC_MIND_READING=0

# Dogs of the Desert faction spawn with dogs (True/False)
# DOGS_SPAWN_WITH_DOGS=False

# Players can only cross the desert boundary once (True/False)
# CROSS_DESERT_ONCE=True

# ============================================
# PVP SCHEDULE (for pve-c or pvp mode)
# ============================================
# Set specific hours when PvP is active (0-24, 24-hour format)
# Only works when SERVER_TYPE=pve-c or pvp

# Restrict PvP to specific hours? (True/False)
# RESTRICT_PVP_TIME=False

# PvP hours per day (start and end in 24h format, e.g. 17 = 5 PM)
# PVP_TIME_MON_START=0
# PVP_TIME_MON_END=0
# PVP_TIME_TUE_START=0
# PVP_TIME_TUE_END=0
# PVP_TIME_WED_START=0
# PVP_TIME_WED_END=0
# PVP_TIME_THU_START=0
# PVP_TIME_THU_END=0
# PVP_TIME_FRI_START=0
# PVP_TIME_FRI_END=0
# PVP_TIME_SAT_START=0
# PVP_TIME_SAT_END=0
# PVP_TIME_SUN_START=0
# PVP_TIME_SUN_END=0

# Restrict building damage to specific hours? (True/False)
# RESTRICT_PVP_BUILDING_DAMAGE_TIME=False

# Building damage hours per day
# PVP_BUILD_MON_START=0
# PVP_BUILD_MON_END=0
# PVP_BUILD_TUE_START=0
# PVP_BUILD_TUE_END=0
# PVP_BUILD_WED_START=0
# PVP_BUILD_WED_END=0
# PVP_BUILD_THU_START=0
# PVP_BUILD_THU_END=0
# PVP_BUILD_FRI_START=0
# PVP_BUILD_FRI_END=0
# PVP_BUILD_SAT_START=0
# PVP_BUILD_SAT_END=0
# PVP_BUILD_SUN_START=0
# PVP_BUILD_SUN_END=0

# Disable building during PvP restricted time (True/False)
# DISABLE_BUILDING_DURING_PVP=False

# ============================================
# AVATARS / GODS
# ============================================

# Disable avatar/god summoning entirely (True/False)
# AVATARS_DISABLED=False

# How long avatars last (seconds, 600 = 10 min)
# AVATAR_LIFETIME=600

# Time to summon an avatar (seconds)
# AVATAR_SUMMON_TIME=60

# Avatar protection dome duration multiplier
# AVATAR_DOME_DURATION=1.0

# Avatar protection dome damage multiplier
# AVATAR_DOME_DAMAGE=1.0

# Restrict avatar summoning to specific times (True/False)
# RESTRICT_AVATAR_TIME=False
# AVATAR_WEEKDAY_START=0
# AVATAR_WEEKDAY_END=0
# AVATAR_WEEKEND_START=0
# AVATAR_WEEKEND_END=0

# ============================================
# UI & SOCIAL
# ============================================

# Enable voice chat (1=on, 0=off)
# VOICE_CHAT=1

# Show online players in player list (0=hide, 1=show)
# SHOW_ONLINE_PLAYERS=0

# Max death location markers on map
# MAX_DEATH_MARKERS=3

# Show clan member markers on map (True/False)
# ENABLE_CLAN_MARKERS=True

# Healthbar visibility distance
# HEALTHBAR_DISTANCE=15000

# Disable chat formatting like colors etc. (True/False)
# DISABLE_CHAT_FORMATTING=False

# Event log privacy for PvP actions (0=show all, 1=partial, 2=hidden)
# EVENT_LOG_PVP_PRIVACY=2

# Event log privacy for PvE actions
# EVENT_LOG_PVE_PRIVACY=1

# Enable in-game event system (purges etc.) (True/False)
# EVENT_SYSTEM=True

# ============================================
# REGION RESTRICTIONS
# ============================================
# Block players from specific regions (True = allow, False = block)

# REGION_ALLOW_AFRICA=True
# REGION_ALLOW_ASIA=True
# REGION_ALLOW_CENTRAL_EUROPE=True
# REGION_ALLOW_EASTERN_EUROPE=True
# REGION_ALLOW_WESTERN_EUROPE=True
# REGION_ALLOW_NORTH_AMERICA=True
# REGION_ALLOW_OCEANIA=True
# REGION_ALLOW_SOUTH_AMERICA=True
# REGION_BLOCK_LIST=

# ============================================
# MODS
# ============================================

# Comma-separated list of Steam Workshop mod IDs
# SERVER_MOD_LIST=

# ============================================
# DURABILITY
# ============================================

# Tool/weapon durability (0 = never breaks, 2.0 = breaks twice as fast)
# DURABILITY=1.0

# Shield durability (0 = shields never break)
# SHIELD_DURABILITY=1.0

# ============================================
# CHAT
# ============================================

# Max chat message length (characters)
# CHAT_MAX_LENGTH=512

# Local chat radius (how close players must be to see local chat)
# CHAT_LOCAL_RADIUS=9000

# Enable global chat channel? (True/False)
# CHAT_HAS_GLOBAL=True

# ============================================
# CLANS
# ============================================

# Max clan size (0 = unlimited)
# CLAN_MAX_SIZE=0

# ============================================
# CRAFTING (EXTRA)
# ============================================

# Thrall crafting/training time (0.5 = train twice as fast)
# THRALL_CRAFTING_TIME=1.0

# Crafting speed at stations (higher = faster)
# CRAFTING_SPEED=1.0

# ============================================
# THRALL KNOCKOUT
# ============================================

# How long knocked out thralls stay unconscious (seconds, 600 = 10 min)
# THRALL_WAKEUP_TIME=600

# ============================================
# PET & HUNGER SYSTEM
# ============================================

# Enable hunger for thralls? (True/False)
# HUNGER_SYSTEM_THRALLS=True

# Enable hunger for pets? (True/False)
# HUNGER_SYSTEM_PETS=True

# Time before companions starve (minutes, 10080 = 7 days)
# STARVATION_TIME=10080

# Max health lost from starvation (0.2 = 20% of max HP)
# STARVATION_DAMAGE_CAP=0.2

# Companions can only eat their specific diet? (True/False)
# EXCLUSIVE_DIET=False

# ============================================
# PURGE
# ============================================

# Enable purge events? (True/False)
# PURGE_ENABLED=True

# Purge difficulty level (1-6, higher = harder)
# PURGE_LEVEL=6

# Restrict purge to specific times? (True/False)
# RESTRICT_PURGE_TIME=True

# Warning time before purge starts (minutes)
# PURGE_PREP_TIME=10

# Max purge duration (minutes)
# PURGE_DURATION=30

# Min online players to trigger purge (0 = offline purges allowed)
# PURGE_MIN_PLAYERS=1

# Allow building during purge? (True/False)
# PURGE_ALLOW_BUILDING=True

# Purge meter trigger value (lower = purges happen sooner)
# PURGE_TRIGGER_VALUE=42000

# Purge NPC damage to buildings multiplier
# PURGE_NPC_BUILDING_DAMAGE=1.0

# ============================================
# PVP BLITZ
# ============================================

# PvP Blitz mode — faster progression for quick PvP (True/False)
# PVP_BLITZ=False

# ============================================
# ADVANCED / ANTI-EXPLOIT
# ============================================

# Enable VAC (Valve Anti-Cheat)
# VAC_ENABLED=False

# Server validates player stats for cheating
# VALIDATE_PLAYER_STATS=False

# Maximum network rate per client
# MAX_CLIENT_RATE=15000

# RCON max karma before throttling
# RCON_MAX_KARMA=60
