# ============================================
# Conan Exiles Server Configuration
# ============================================
# Copy this file to .env and edit as needed:
#   cp .env.example .env

# Server Info
SERVER_NAME=My Conan Server
SERVER_PASSWORD=
SERVER_TYPE=pve
# Options: pve, pvp, pve-c

# Capacity
MAX_PLAYERS=40

# Admin
ADMIN_PASSWORD=changeme

# RCON (Remote Console)
RCON_ENABLED=False
RCON_PASSWORD=changeme
RCON_PORT=25575

# Network
SERVER_PORT=7777
QUERY_PORT=27015

# Region
# 0 = EU (Europe, Middle East, Africa)
# 1 = NA (North America)
# 2 = Asia
# 3 = Oceania (Australia, New Zealand)
# 4 = SA (South America)
# 5 = Japan
SERVER_REGION=0

# Anti-Cheat
BATTLEYE_ENABLED=False

# Timezone
# Examples: UTC, America/New_York, Europe/London, Asia/Qatar, Asia/Tokyo
TZ=UTC
