# ============================================
# CONAN EXILES DEDICATED SERVER CONFIGURATION
# ============================================
# Copy this file to .env and edit as needed:
#   cp .env.example .env
#
# Uncomment (remove #) any setting to override the default value.
# After changing, restart: docker compose restart

# ============================================
# SERVER INFO
# ============================================

# Server name shown in the server browser
SERVER_NAME=My Conan Server

# Password to join (empty = public server)
SERVER_PASSWORD=

# Server type: pve, pvp, or pve-c (pve with scheduled pvp hours)
SERVER_TYPE=pve

# Max players (1-40)
MAX_PLAYERS=40

# Message of the day shown when players join
# SERVER_MOTD=Welcome to our server!

# Region: 0=EU, 1=NA, 2=Asia, 3=Oceania, 4=SA, 5=Japan
SERVER_REGION=0

# Timezone (examples: UTC, America/New_York, Europe/London, Asia/Qatar)
TZ=UTC

# ============================================
# ADMIN
# ============================================

# In-game admin password (use MakeMeAdmin in console)
ADMIN_PASSWORD=changeme

# RCON remote console (True/False)
RCON_ENABLED=False
RCON_PASSWORD=changeme
RCON_PORT=25575

# ============================================
# NETWORK
# ============================================

SERVER_PORT=7777
QUERY_PORT=27015

# Kick AFK players after this many seconds (default: 2700 = 45 min)
# KICK_AFK_TIME=2700

# Max allowed ping (0 = no limit)
# MAX_ALLOWED_PING=0

# Enable login queue when server is full (True/False)
# ENABLE_LOGIN_QUEUE=True

# ============================================
# COMBAT & DAMAGE
# ============================================

# Player damage dealt multiplier (1.0 = normal, 2.0 = double)
# PLAYER_DAMAGE=1.0

# Player damage taken multiplier (1.0 = normal, 0.5 = take half)
# PLAYER_DAMAGE_TAKEN=1.0

# NPC/enemy damage dealt (1.0 = normal)
# NPC_DAMAGE=1.0

# NPC/enemy damage taken (1.0 = normal, 2.0 = enemies die faster)
# NPC_DAMAGE_TAKEN=1.0

# Thrall/follower damage to players (1.0 = full, 0.5 = half)
# THRALL_DAMAGE_TO_PLAYERS=0.5

# Thrall/follower damage to NPCs (1.0 = full)
# THRALL_DAMAGE_TO_NPCS=0.5

# Friendly fire damage multiplier
# FRIENDLY_FIRE_DAMAGE=0.25

# Structure damage multiplier
# STRUCTURE_DAMAGE=1.0

# Building damage multiplier
# BUILDING_DAMAGE=1.0

# Can players damage their own structures? (True/False)
# CAN_DAMAGE_OWN_STRUCTURES=False

# Enable target lock in combat (True/False)
# ENABLE_TARGET_LOCK=True

# Enable fatality/finishing moves (True/False)
# ENABLE_FATALITIES=True

# ============================================
# DEATH & LOOTING
# ============================================

# Can all players loot dead bodies? (True/False)
# True = anyone can loot, False = only the owner
EVERYBODY_LOOT_CORPSE=True

# Drop equipment on death? (True/False)
# DROP_EQUIPMENT_ON_DEATH=False

# Character stays in world after logout? (True/False)
# LOGOUT_REMAIN=True

# How long unconscious body stays after logout (seconds, default: 1800 = 30 min)
# UNCONSCIOUS_TIME=1800

# Max corpses per player (oldest removed when exceeded)
# CORPSES_PER_PLAYER=10

# How long player corpses last (seconds, default: 1800 = 30 min)
# PLAYER_CORPSE_LIFETIME=1800

# How long NPC corpses last (seconds, default: 600 = 10 min)
# NPC_CORPSE_LIFETIME=600

# ============================================
# XP & PROGRESSION
# ============================================

# Overall XP multiplier (1.0 = normal, 2.0 = double)
# XP_RATE=1.0

# XP from killing
# XP_KILL=1.0

# XP from harvesting
# XP_HARVEST=1.0

# XP from crafting
# XP_CRAFT=1.0

# XP over time (passive XP)
# XP_TIME=1.0

# ============================================
# HARVESTING & CRAFTING
# ============================================

# Harvest amount multiplier (2.0 = get double resources)
# HARVEST_AMOUNT=1.0

# Resource respawn speed (lower = faster respawn)
# RESOURCE_RESPAWN=1.0

# Food/item spoil rate (higher = spoils faster, lower = lasts longer)
# ITEM_SPOIL_RATE=1.0

# Crafting cost multiplier (0.5 = half the materials needed)
# CRAFTING_COST=1.0

# Fuel burn time multiplier (2.0 = fuel lasts twice as long)
# FUEL_BURN_TIME=1.0

# Item conversion speed multiplier
# ITEM_CONVERSION=1.0

# ============================================
# STAMINA & MOVEMENT
# ============================================

# Stamina cost multiplier (0.5 = uses half stamina)
# STAMINA_COST=1.0

# Sprint stamina cost multiplier
# STAMINA_SPRINT_COST=1.0

# Player movement speed (1.0 = normal)
# PLAYER_MOVE_SPEED=1.0

# Player sprint speed (1.0 = normal)
# PLAYER_SPRINT_SPEED=1.0

# Health regeneration speed (higher = faster healing)
# HEALTH_REGEN_SPEED=1.0

# ============================================
# THRALLS & FOLLOWERS
# ============================================

# Thrall conversion time on wheel (lower = faster, 0.5 = half time)
# THRALL_CONVERSION=1.0

# Thrall scouting time in minutes
# THRALL_SCOUTING_TIME=10

# Use follower population limit? (True/False)
# USE_MINION_POP_LIMIT=False

# Base follower population limit
# MINION_POP_BASE=50

# Extra followers allowed per player
# MINION_POP_PER_PLAYER=5

# Enable follower rescue (True/False)
# ENABLE_FOLLOWER_RESCUE=True

# Follower rescue cooldown (seconds)
# FOLLOWER_RESCUE_COOLDOWN=3600

# Thrall corruption removal speed
# THRALL_CORRUPTION_REMOVAL=1.0

# Player corruption gain multiplier
# PLAYER_CORRUPTION_GAIN=1.0

# ============================================
# BUILDING & DECAY
# ============================================

# Land claim radius multiplier
# LAND_CLAIM_RADIUS=1.0

# Allow building anywhere? (True/False)
# BUILD_ANYWHERE=False

# Enable building pickup (True/False)
# BUILDING_PICKUP=True

# Stability loss multiplier
# STABILITY_LOSS=1.0

# Disable building abandonment/decay (True/False)
# DISABLE_BUILDING_DECAY=True

# Max building decay time (seconds, default: 1296000 = 15 days)
# MAX_BUILDING_DECAY_TIME=1296000

# Disable thrall decay (True/False)
# DISABLE_THRALL_DECAY=True

# Thrall decay time (seconds, default: 1296000 = 15 days)
# THRALL_DECAY_TIME=1296000

# ============================================
# NPC & WORLD
# ============================================

# NPC health multiplier (2.0 = enemies have double HP)
# NPC_HEALTH=1.0

# NPC respawn speed (lower = faster)
# NPC_RESPAWN=1.0

# NPC max spawn cap multiplier
# NPC_MAX_SPAWN_CAP=1.0

# Enable ambient wildlife (True/False)
# AMBIENT_LIFE=True

# Max aggro range
# MAX_AGGRO_RANGE=9000

# ============================================
# EVENTS & FEATURES
# ============================================

# Disable avatars/gods (True/False)
# AVATARS_DISABLED=False

# Avatar lifetime (seconds)
# AVATAR_LIFETIME=600

# Enable event system (True/False)
# EVENT_SYSTEM=True

# Enable voice chat (1=on, 0=off)
# VOICE_CHAT=1

# Show online players in player list (0=off, 1=on)
# SHOW_ONLINE_PLAYERS=0

# Max death map markers
# MAX_DEATH_MARKERS=3

# Nudity level (0=none, 1=partial, 2=full)
# MAX_NUDITY=2

# Anti-cheat
BATTLEYE_ENABLED=False

# Allow family shared Steam accounts (True/False)
# ALLOW_FAMILY_SHARE=True

# ============================================
# REGION RESTRICTIONS
# ============================================
# Block players from specific regions (all True by default)

# REGION_ALLOW_AFRICA=True
# REGION_ALLOW_ASIA=True
# REGION_ALLOW_CENTRAL_EUROPE=True
# REGION_ALLOW_EASTERN_EUROPE=True
# REGION_ALLOW_WESTERN_EUROPE=True
# REGION_ALLOW_NORTH_AMERICA=True
# REGION_ALLOW_OCEANIA=True
# REGION_ALLOW_SOUTH_AMERICA=True
